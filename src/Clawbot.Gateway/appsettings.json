{
  "Urls": "http://0.0.0.0:5050",
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "File", "Args": { "path": "logs/gateway-.log", "rollingInterval": "Day" } }
    ],
    "Enrich": ["FromLogContext"]
  },
  "Gateway": {
    "Pancake": {
      "WebhookSecret": "REPLACE_WITH_SECRET"
    },
    "RateLimit": {
      "WebhookPermitLimit": 100,
      "WebhookWindowSeconds": 10,
      "ApiPermitLimit": 200,
      "ApiWindowSeconds": 10
    }
  },
  "ReverseProxy": {
    "Routes": {
      "pancake-webhook": {
        "ClusterId": "backend",
        "Match": { "Path": "/webhook/{**catch-all}" },
        "Metadata": { "RequiresHmac": "true" }
      },
      "api-routes": {
        "ClusterId": "backend",
        "Match": { "Path": "/api/{**catch-all}" }
      },
      "signalr-hub": {
        "ClusterId": "backend",
        "Match": { "Path": "/hubs/{**catch-all}" }
      }
    },
    "Clusters": {
      "backend": {
        "Destinations": {
          "backend/primary": {
            "Address": "http://localhost:5051"
          }
        }
      }
    }
  }
}
